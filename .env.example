# ===========================
# CPA 服务器配置（必填）
# ===========================

CPA_BASE_URL=http://localhost:8317
CPA_MANAGEMENT_KEY=your-management-key-here

# ===========================
# 定时任务配置（可选）
# ===========================

CRON_ENABLED=false
CRON_SCHEDULE=0 0 * * *
REFRESH_MODE=quota-check

# ===========================
# 服务配置（可选）
# ===========================

PORT=3000
