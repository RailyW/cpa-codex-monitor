# ===========================
# CPA 服务器配置（必填）
# ===========================

CPA_BASE_URL=http://localhost:8317
CPA_MANAGEMENT_KEY=your-management-key-here

# ===========================
# 定时任务配置（可选）
# 定时任务仅在 npm run start (tsx server.ts) 下运行，next dev 下不会执行。
# ===========================

CRON_ENABLED=false

# 时区（IANA 名称），用于定时执行时刻
# 北京: Asia/Shanghai
CRON_TIMEZONE=Asia/Shanghai

# 每天在以下时刻执行刷新（24 小时制，逗号分隔），基于网络授时（WorldTimeAPI）
# 该刷新任务会向每个 Codex 账号发起一次极简请求，用于刷新任务用量计费时间窗口。
# 例：每天 06:00 和 11:00 北京时间
CRON_TIMES=06:00,11:00

# ===========================
# 额度查询配置（可选）
# ===========================

# 服务端轮询 CPA 查询所有账号额度的间隔（秒），默认 300（5 分钟）
QUOTA_CHECK_INTERVAL=300

# ===========================
# 服务配置（可选）
# ===========================

PORT=3000
